{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Issue",
  "type": "object",
  "required": [
    "id",
    "category",
    "severity",
    "title",
    "description",
    "location",
    "evidence",
    "suggested_fix",
    "confidence"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "minor",
        "major",
        "critical"
      ]
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "location": {
      "type": "object"
    },
    "evidence": {
      "type": "array"
    },
    "suggested_fix": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}